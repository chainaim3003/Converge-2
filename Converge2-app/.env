# CRE - Environment Configuration
# Trade Finance Platform on Chainlink Runtime Environment
# Network: Ethereum Sepolia (Chain ID: 11155111)

# =====================================
# ETHEREUM SEPOLIA NETWORK
# =====================================
NEXT_PUBLIC_ETH_NETWORK=sepolia
NEXT_PUBLIC_ETH_RPC_URL=https://rpc.sepolia.org
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_SEPOLIA_EXPLORER=https://sepolia.etherscan.io

# =====================================
# DEPLOYED CONTRACTS - ETHEREUM SEPOLIA
# =====================================
# cvUSD (Converge Stablecoin) ERC-20
# https://sepolia.etherscan.io/address/0x8D8131547Ec5Cb2fF1bB941a28fA20e347A928F3
NEXT_PUBLIC_CVUSD_CONTRACT_ADDRESS=0x8D8131547Ec5Cb2fF1bB941a28fA20e347A928F3

# =====================================
# WALLET ADDRESSES (Ethereum 0x... format)
# Set these to your MetaMask wallet addresses.
# Payments are signed by MetaMask — no seeds stored here.
# =====================================
NEXT_PUBLIC_BUYER_WALLET_ADDRESS=
NEXT_PUBLIC_SELLER_WALLET_ADDRESS=
NEXT_PUBLIC_PLATFORM_WALLET_ADDRESS=

# =====================================
# PLATFORM SETTINGS
# =====================================
NEXT_PUBLIC_MARKETPLACE_FEE=0.25
NEXT_PUBLIC_TAX_RATE=18
NEXT_PUBLIC_PAYMENT_CURRENCY=cvUSD

# =====================================
# APPLICATION SETTINGS
# =====================================
NEXT_PUBLIC_APP_NAME=CRE
NEXT_PUBLIC_APP_DESCRIPTION=Trade Finance Platform on Chainlink Runtime Environment
NEXT_PUBLIC_DEMO_MODE=true

# =====================================
# API
# =====================================
NEXT_PUBLIC_API_URL=http://localhost:4000

# =====================================
# KERI/vLEI (unchanged)
# =====================================
KERI_AGENT_URL=http://localhost:3001
VLEI_REGISTRY_URL=http://localhost:3002
