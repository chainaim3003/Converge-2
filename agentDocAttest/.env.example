# =====================================
# agentDocAttest — Environment Configuration
# DocAttest: AI Trade Assessment via Chainlink CRE
# =====================================

# =====================================
# CRE (Chainlink Runtime Environment)
# =====================================
# Private key for CRE workflow deployment (Base Sepolia)
# Must have Base Sepolia ETH for gas
CRE_ETH_PRIVATE_KEY=

# CRE target environment
# Reference: docs.chain.link/cre/getting-started/overview
CRE_TARGET=staging-settings

# =====================================
# LLM — AI Trade Assessment
# =====================================
# Gemini API key (free from aistudio.google.com/api-keys)
# Or any OpenAI-compatible LLM endpoint
# Reference: cre-bootcamp-2026 uses Gemini
LLM_API_KEY=

# LLM endpoint URL
# Default: Gemini 2.0 Flash (proven in cre-bootcamp-2026)
LLM_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent

# =====================================
# SMART CONTRACT (Base Sepolia)
# =====================================
# TradeRegistry.sol deployed address (set after forge create)
TRADE_REGISTRY_ADDRESS=

# Base Sepolia CRE Forwarder (from x402-cre-price-alerts README)
CRE_FORWARDER_ADDRESS=0x82300bd7c3958625581cc2f77bc6464dcecdf3e5

# Base Sepolia Chain Selector (from docs.chain.link/cre/supported-networks-ts)
BASE_SEPOLIA_CHAIN_SELECTOR=16015286601757825753

# Base Sepolia RPC
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# =====================================
# GATEWAY
# =====================================
GATEWAY_PORT=3002

# Private key for gateway to submit transactions to TradeRegistry
# Must have Base Sepolia ETH for gas
GATEWAY_PRIVATE_KEY=

# =====================================
# PLATFORM (from Converge2-app/.env)
# =====================================
PLATFORM_WALLET_ADDRESS=0x5A0368AA6750159b3135645F86300dd1dCBf0C73
